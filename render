services:
  - type: web
    name: travel-services-bot
    env: python
    buildCommand: "pip install -r requirements.txt"
    startCommand: "gunicorn --workers 2 --threads 4 --bind 0.0.0.0:$PORT bot:flask_app"
    envVars:
      - key: TELEGRAM_BOT_TOKEN
        sync: false
      - key: GEMINI_API_KEY
        sync: false
